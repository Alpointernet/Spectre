<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Spectre.Views.SearchOverlayControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="Root" Background="{DynamicResource SearchOverlayBackground}" Visibility="Collapsed" Opacity="0" xmlns:views="clr-namespace:Spectre.Views;assembly=Spectre" MouseLeftButtonDown="SearchOverlay_MouseLeftButtonDown">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Name="RecentSearchesPanel" Margin="40,75,40,40">
      <TextBlock Text="Recent Searches" Foreground="{DynamicResource TextBrush}" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" />
      <WrapPanel Name="RecentSearchesWrapPanel" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
