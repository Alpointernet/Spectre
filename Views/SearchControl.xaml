<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Spectre.Views.SearchControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"  x:Name="Root" xmlns:views="clr-namespace:Spectre.Views;assembly=Spectre">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <Storyboard x:Key="FocusAnim">
        <DoubleAnimation Storyboard.TargetName="SearchBorder" Storyboard.TargetProperty="Width" To="500" Duration="0:0:0.25">
          <DoubleAnimation.EasingFunction>
            <QuarticEase EasingMode="EaseOut" />
          </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetName="SearchFocusBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.25">
          <DoubleAnimation.EasingFunction>
            <QuarticEase EasingMode="EaseOut" />
          </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
      </Storyboard>
      <Storyboard x:Key="LostFocusAnim">
        <DoubleAnimation Storyboard.TargetName="SearchBorder" Storyboard.TargetProperty="Width" To="300" Duration="0:0:0.25">
          <DoubleAnimation.EasingFunction>
            <QuarticEase EasingMode="EaseOut" />
          </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetName="SearchFocusBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25">
          <DoubleAnimation.EasingFunction>
            <QuarticEase EasingMode="EaseOut" />
          </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
      </Storyboard>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid>
    <Border Name="SearchBorder" BorderThickness="1" CornerRadius="16" Height="32" Width="300" HorizontalAlignment="Left">
      <FrameworkElement.Style>
        <Style TargetType="{x:Type Border}">
          <Setter Property="Background" Value="#0DFFFFFF" />
          <Setter Property="BorderBrush" Value="#0FFFFFFF" />
          <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
              <BeginStoryboard>
                <Storyboard>
                  <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)" To="#1CFFFFFF" Duration="0:0:0.05" />
                  <ColorAnimation Storyboard.TargetProperty="BorderBrush.(SolidColorBrush.Color)" To="#25FFFFFF" Duration="0:0:0.05" />
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
              <BeginStoryboard>
                <Storyboard>
                  <ColorAnimation Storyboard.TargetProperty="Background.(SolidColorBrush.Color)" To="#0DFFFFFF" Duration="0:0:0.05" />
                  <ColorAnimation Storyboard.TargetProperty="BorderBrush.(SolidColorBrush.Color)" To="#0FFFFFFF" Duration="0:0:0.05" />
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
          </Style.Triggers>
        </Style>
      </FrameworkElement.Style>
      <Grid>
        <Border Name="SearchFocusBorder" BorderBrush="{DynamicResource AccentGradient}" BorderThickness="1" CornerRadius="16" Margin="0" Opacity="0">
        </Border>
        <Image Source="{StaticResource searchIcon}" Width="14" Height="14" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Opacity="0.5" />
        <TextBlock Name="SearchPlaceholder" Text="Search" Foreground="{DynamicResource TextBrush}" Opacity="0.5" Padding="35,5,10,5" VerticalAlignment="Center" IsHitTestVisible="False" Margin="1,0,0,0" />
        <TextBox Name="SearchBox" Background="#00FFFFFF" Foreground="{DynamicResource TextBrush}" CaretBrush="#FFFFFFFF" BorderThickness="0" Padding="35,5,10,5" Text="" VerticalAlignment="Center" GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus" KeyDown="SearchBox_KeyDown" TextChanged="SearchBox_TextChanged" />
      </Grid>
    </Border>
  </Grid>
</UserControl>


