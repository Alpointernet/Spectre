<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Spectre.Views.SidebarTab" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"  x:Name="Root" Background="#00FFFFFF" Cursor="Hand" Margin="0,0,0,5" xmlns:views="clr-namespace:Spectre.Views;assembly=Spectre">
  <Border Name="MainBorder" CornerRadius="6" Padding="8,5,0,5" Background="#00FFFFFF">
    <UIElement.InputBindings>
      <MouseBinding MouseAction="LeftClick" Command="{Binding Command, ElementName=Root}" CommandParameter="{Binding PageId, ElementName=Root}" />
    </UIElement.InputBindings>
    <StackPanel Orientation="Horizontal">
      <Border Width="32" Height="32" Margin="0,0,10,0">
        <Grid>
          <Image Name="IconViewbox" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
          <Rectangle Name="IconTintRectangle" Fill="{Binding Foreground, ElementName=TitleText}" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Rectangle.OpacityMask>
              <VisualBrush Visual="{Binding ElementName=IconViewbox}" Stretch="None" />
            </Rectangle.OpacityMask>
          </Rectangle>
        </Grid>
      </Border>
      <TextBlock Name="TitleText" Foreground="{DynamicResource SidebarTextBrush}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Text="{Binding Text, ElementName=Root}" />
    </StackPanel>
  </Border>
</UserControl>


