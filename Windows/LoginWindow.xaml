<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Spectre.LoginWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" Title="Login to YouTube Music" Height="600" Width="800" WindowStartupLocation="CenterOwner" Background="#121212" xmlns:spectre="clr-namespace:Spectre;assembly=Spectre">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Name="StatusTextBlock" Grid.Row="0" Foreground="#FFFFFFFF" FontSize="18" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,20" TextWrapping="Wrap">Loading Login Page...</TextBlock>
    <wv2:WebView2 Name="webView" Grid.Row="0" Visibility="Hidden" />
    <Button Name="DoneButton" Grid.Row="1" Content="I'm Logged In" Height="40" Margin="10" Background="#282828" Foreground="#FFFFFFFF" FontSize="16" FontWeight="Bold" Visibility="Hidden" Cursor="Hand" BorderThickness="0" Click="DoneButton_Click" />
  </Grid>
</Window>