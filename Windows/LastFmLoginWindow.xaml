<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Spectre.LastFmLoginWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" Title="Last.fm Login" Height="700" Width="900" WindowStartupLocation="CenterOwner" Background="#121212" xmlns:spectre="clr-namespace:Spectre;assembly=Spectre">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Border Background="#1e1e1e" Padding="15">
      <StackPanel Name="InstructionsPanel">
        <TextBlock Name="StepText" Text="Step 1: Obtain API Keys" Foreground="#FFFFFFFF" FontSize="18" FontWeight="Bold" Margin="0,0,0,5" />
        <TextBlock Name="DescText" Text="Please log in to Last.fm. If you don't have an API account, click 'Add API account', fill out dummy data (e.g., 'Spectre Player' for the name), and submit. Once you see your API Key on the screen, click 'I have my keys'." Foreground="#cccccc" TextWrapping="Wrap" FontSize="14" />
      </StackPanel>
    </Border>
    <wv2:WebView2 Name="webView" Grid.Row="1" />
    <Border Grid.Row="2" Background="#1e1e1e" Padding="15">
      <Grid>
        <Button Name="DoneButton" Content="I have my keys" HorizontalAlignment="Right" Padding="20,10" Background="#F87171" Foreground="#FFFFFFFF" BorderThickness="0" FontWeight="Bold" FontSize="14" Cursor="Hand" Click="DoneButton_Click">
          <Control.Template>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Background="{TemplateBinding Control.Background}" CornerRadius="20" Padding="{TemplateBinding Control.Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </ControlTemplate>
          </Control.Template>
        </Button>
      </Grid>
    </Border>
    <Border Name="ManualEntryOverlay" Grid.Row="0" Grid.RowSpan="3" Background="#cc000000" Visibility="Collapsed">
      <Border Background="#1e1e1e" CornerRadius="12" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
        <StackPanel>
          <TextBlock Text="Enter API Keys" FontSize="20" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,0,0,20" />
          <TextBlock Text="API Key" Foreground="#cccccc" Margin="0,0,0,5" />
          <TextBox Name="ManualApiKeyBox" Background="#2e2e2e" Foreground="#FFFFFFFF" BorderThickness="0" Padding="10" Margin="0,0,0,15" />
          <TextBlock Text="Shared Secret" Foreground="#cccccc" Margin="0,0,0,5" />
          <TextBox Name="ManualSharedSecretBox" Background="#2e2e2e" Foreground="#FFFFFFFF" BorderThickness="0" Padding="10" Margin="0,0,0,20" />
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Background="#00FFFFFF" Foreground="#cccccc" BorderThickness="0" Padding="15,10" Margin="0,0,10,0" Cursor="Hand" Click="ManualCancel_Click" />
            <Button Content="Submit" Background="#F87171" Foreground="#FFFFFFFF" BorderThickness="0" Padding="20,10" FontWeight="Bold" Cursor="Hand" Click="ManualSubmit_Click">
              <Control.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                  <Border Background="{TemplateBinding Control.Background}" CornerRadius="20" Padding="{TemplateBinding Control.Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                </ControlTemplate>
              </Control.Template>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</Window>